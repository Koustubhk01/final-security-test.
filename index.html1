<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Scam Awareness Trainer</title>
    <style>
        body { font-family: sans-serif; background: #eef2f3; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
        .card { background: white; padding: 40px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); width: 350px; text-align: center; }
        button { background: #5a32a3; color: white; border: none; padding: 12px 20px; margin: 5px 0; border-radius: 8px; cursor: pointer; width: 100%; }
        .red-flag { color: #d93025; font-weight: bold; }
        #timer { color: red; font-weight: bold; margin-bottom: 10px; }
    </style>
</head>
<body>

<div class="card">
    <div id="timer">Time left: 10s</div>
    <h3 id="title">Loading...</h3>
    <p id="text"></p>
    <div id="actions"></div>
    <p>Score: <span id="score">0</span></p>
</div>

<script>
    const scenarios = [
        { title: "Bank Alert", text: "Alert: Your account is blocked. Click here to verify: bit.ly/bank-fix", redFlag: "Red Flag: Shortened URLs and artificial urgency.", tip: "Never share your OTP." },
        { title: "Scam Call", text: "Caller: I am from the Police, your number is under investigation. Share OTP.", redFlag: "Red Flag: Authorities never ask for OTPs.", tip: "Always verify official IDs." }
    ];

    let index = 0, score = 0, timeLeft = 10;

    const timer = setInterval(() => {
        timeLeft--;
        document.getElementById('timer').innerText = "Time left: " + timeLeft + "s";
        if (timeLeft <= 0) { clearInterval(timer); reveal(false); }
    }, 1000);

    function load() {
        document.getElementById('title').innerText = scenarios[index].title;
        document.getElementById('text').innerText = scenarios[index].text;
        document.getElementById('actions').innerHTML = `<button onclick="reveal(true)">Analyze</button>`;
    }

    function reveal(isSafe) {
        clearInterval(timer);
        if(isSafe) score += 10;
        document.getElementById('score').innerText = score;
        document.getElementById('text').innerHTML = `<p class="red-flag">${scenarios[index].redFlag}</p><p>${scenarios[index].tip}</p>`;
        document.getElementById('actions').innerHTML = `<button onclick="next()">Next Scenario</button>`;
        
        // Voice-based explanation [cite: 302]
        const msg = new SpeechSynthesisUtterance(scenarios[index].tip);
        window.speechSynthesis.speak(msg);
    }

    function next() {
        index = (index + 1) % scenarios.length;
        timeLeft = 10;
        load();
    }

    load();
</script>
</body>
</html>
